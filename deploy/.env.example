# Переменные для docker-compose (скопируй в deploy/.env). Реальные значения не коммитим.

# --- PostgreSQL ---
POSTGRES_USER=aegis
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aegis

# --- Веб-панель ---
AEGIS_WEB_SECRET_KEY=change-me-long-random
# через запятую, только имена хостов (без схемы). Пример:
#   localhost,127.0.0.1,fraudulently-impish-longhorn.cloudpub.ru
AEGIS_WEB_ALLOWED_HOSTS=*
# через запятую, со схемой (обязательно для внешних доменов), пример:
#   https://fraudulently-impish-longhorn.cloudpub.ru
AEGIS_WEB_CSRF_ORIGINS=
# 1, если панель за https-туннелем (CloudPub, Cloudflare, nginx) — включит
# доверие X-Forwarded-Proto и secure-куки.
AEGIS_WEB_BEHIND_PROXY=0
# стартовый администратор (создаётся при первом запуске):
AEGIS_ADMIN_USER=admin
AEGIS_ADMIN_PASSWORD=change-me
# опциональный наблюдатель (только чтение):
AEGIS_OBSERVER_USER=
AEGIS_OBSERVER_PASSWORD=

# --- Telegram-алерты (опционально) ---
AEGIS_TELEGRAM_TOKEN=
AEGIS_TELEGRAM_CHAT_ID=
AEGIS_ALERT_MIN_SEVERITY=WARNING

# --- Grafana ---
GRAFANA_PASSWORD=change-me
# Полный публичный URL Grafana (со схемой). Пример:
#   https://richly-creditable-tanager.cloudpub.ru
GRAFANA_ROOT_URL=
